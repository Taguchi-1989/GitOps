{
  "name": "flowops",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "node scripts/next-build.js",
    "start": "next start",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "db:seed": "ts-node -P tsconfig.seed.json --transpile-only prisma/seed.ts",
    "validate:flows": "ts-node -r tsconfig-paths/register -P tsconfig.seed.json --transpile-only scripts/validate-flows.ts",
    "governance:gate": "ts-node -r tsconfig-paths/register -P tsconfig.seed.json --transpile-only scripts/governance-gate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\"",
    "prepare": "husky",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.112.3",
    "@auth/prisma-adapter": "^2.11.2",
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/bcryptjs": "^3.0.0",
    "@xyflow/react": "^12.11.2",
    "ajv": "^8.20.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.11.1",
    "dagre": "^0.8.5",
    "fast-xml-parser": "^5.10.1",
    "lucide-react": "^1.25.0",
    "mermaid": "^11.16.0",
    "next": "^16.2.10",
    "next-auth": "^5.0.0-beta.31",
    "openai": "^6.48.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "prisma": "^7.8.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "simple-git": "^3.36.0",
    "yaml": "^2.9.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/dagre": "^0.7.54",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.5",
    "autoprefixer": "^10.5.0",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.19",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix --max-warnings=0"
    ],
    "src/**/*.css": [
      "prettier --write"
    ]
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "overrides": {
    "@prisma/dev": {
      "@hono/node-server": "^1.19.13"
    },
    "postcss": "$postcss"
  }
}
