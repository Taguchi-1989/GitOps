# FlowOps Environment Variables
#
# =====================================================================
# ローカル最小構成（初心者向け / LiteLLM・Langfuse なし）
# =====================================================================
# PostgreSQLだけDockerで起動: docker compose up postgres -d
# LLMは直接プロバイダーを指定（LiteLLM不要）
#
# --- この3つを設定すれば動きます ---
DATABASE_URL="postgresql://flowops:flowops@localhost:5432/flowops"
AUTH_SECRET=change-me-to-random-secret
LLM_PROVIDER=openai
LLM_API_KEY=sk-your-openai-key
LLM_MODEL=gpt-4o
# --- ここまで ---
#
# 他のプロバイダー例:
#   LLM_PROVIDER=anthropic  LLM_API_KEY=sk-ant-xxx  LLM_MODEL=claude-sonnet-4-5-20250929
#   LLM_PROVIDER=gemini     LLM_API_KEY=AIza-xxx    LLM_MODEL=gemini-2.0-flash
#   LLM_PROVIDER=ollama     LLM_API_KEY=ollama      LLM_MODEL=llama3.2
#
# =====================================================================
# フルスタック構成（Docker Compose で全サービス起動）
# =====================================================================
# docker compose up -d で FlowOps + LiteLLM + Langfuse + PostgreSQL を一括起動
#

# ─── Database (PostgreSQL) ─────────────────────────────
# DATABASE_URL="postgresql://flowops:flowops@localhost:5432/flowops"
DB_PASSWORD=flowops
DB_PORT=5432

# ─── Authentication ──────────────────────────────────────
# AUTH_SECRET=change-me-to-random-secret
ALLOWED_ORIGINS=http://localhost:3000

# ─── Logging ─────────────────────────────────────────────
# LOG_LEVEL=debug

# ─── LLM Configuration ───────────────────────────────────
# LiteLLM経由: provider=custom, BASE_URL=LiteLLMプロキシ
# LLM_PROVIDER=custom
# LLM_API_KEY=sk-litellm-dev
# LLM_BASE_URL=http://localhost:4000/v1
# LLM_MODEL=gpt-4o
# LLM_JSON_MODE=true

# ─── LiteLLM Gateway (Layer 3) ───────────────────────────
LITELLM_MASTER_KEY=sk-litellm-dev
LITELLM_PORT=4000

# 各LLMプロバイダーのAPIキー（LiteLLMが管理）
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GEMINI_API_KEY=your-gemini-key

# ─── Langfuse (Layer 5: Governance) ──────────────────────
LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PORT=3001
LANGFUSE_DB_PASSWORD=langfuse
LANGFUSE_AUTH_SECRET=langfuse-dev-secret
LANGFUSE_SALT=langfuse-dev-salt
LANGFUSE_TELEMETRY=false

# ─── FlowOps App ─────────────────────────────────────────
FLOWOPS_PORT=3000

# ─── Ollama (Layer 4: Local LLM, オプション) ─────────────
# docker compose --profile local-llm up で有効化
OLLAMA_PORT=11434
