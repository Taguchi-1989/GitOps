# FlowOps Environment Variables

# Database
DATABASE_URL="file:./dev.db"

# ─── LLM Configuration ───────────────────────────────────
# プロバイダー名: openai | anthropic | gemini | groq | ollama | custom
LLM_PROVIDER=openai

# APIキー（各プロバイダー共通）
LLM_API_KEY=sk-your-key-here

# モデル名（省略時はプロバイダーのデフォルト）
# LLM_MODEL=gpt-4o

# カスタムベースURL（省略時はプロバイダーのデフォルト）
# LLM_BASE_URL=https://api.openai.com/v1

# JSON modeサポート（true/false, 省略時はプロバイダー依存）
# LLM_JSON_MODE=true

# ─── 後方互換（LLM_API_KEY未設定時のフォールバック） ─────
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o
