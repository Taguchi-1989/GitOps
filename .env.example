# FlowOps environment example
# Copy this file to .env. FlowOps MVP uses SQLite as its canonical database.

# ─── Required ───────────────────────────────────────────────
DATABASE_URL="file:./prisma/dev.db"
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
AUTH_SECRET=replace-with-at-least-32-random-characters
ALLOWED_ORIGINS=http://localhost:3000

# Local development only. This is ignored when NODE_ENV=production.
AUTH_DISABLED=false

# The seed creates/updates this administrator.
FLOWOPS_ADMIN_EMAIL=admin@flowops.local
# Required by Docker Compose and by production seed execution.
FLOWOPS_ADMIN_PASSWORD=replace-with-a-strong-password

# ─── Direct LLM connection (optional) ──────────────────────
# LLM features remain unavailable until a real API key is configured.
LLM_PROVIDER=openai
LLM_API_KEY=sk-replace-with-your-key
LLM_MODEL=gpt-4o
# LLM_BASE_URL=
# LLM_JSON_MODE=true

# AIMS historical-evidence review (optional)
# When omitted, FlowOps uses the LLM settings above for three review roles plus synthesis.
# Configure distinct providers/models as a one-line JSON array; store key names, never keys.
# AIMS_LLM_REVIEWERS=[{"id":"summary","role":"summarizer","provider":"openai","model":"your-approved-model","apiKeyEnv":"OPENAI_API_KEY"},{"id":"audit","role":"auditor","provider":"anthropic","model":"your-approved-model","apiKeyEnv":"ANTHROPIC_API_KEY"},{"id":"synthesis","role":"synthesizer","provider":"gemini","model":"your-approved-model","apiKeyEnv":"GEMINI_API_KEY"}]
AIMS_REVIEW_CHUNK_CHARS=16000
AIMS_MAX_REVIEW_CHUNKS=6

# Other examples:
# LLM_PROVIDER=anthropic  LLM_API_KEY=sk-ant-xxx  LLM_MODEL=claude-sonnet-4-6
# LLM_PROVIDER=gemini     LLM_API_KEY=AIza-xxx    LLM_MODEL=gemini-3-flash
# LLM_PROVIDER=ollama     LLM_API_KEY=ollama      LLM_MODEL=llama3.2

# ─── Docker Compose full stack ─────────────────────────────
FLOWOPS_PORT=3000

# FlowOps talks to LiteLLM with these settings in Docker Compose.
LITELLM_MASTER_KEY=sk-litellm-dev
LITELLM_PORT=4000
OPENAI_API_KEY=sk-replace-with-your-key
ANTHROPIC_API_KEY=sk-ant-replace-with-your-key
GEMINI_API_KEY=replace-with-your-key

# Langfuse keeps its own PostgreSQL database; FlowOps itself remains SQLite.
LANGFUSE_PUBLIC_KEY=pk-lf-replace-with-your-key
LANGFUSE_SECRET_KEY=sk-lf-replace-with-your-key
LANGFUSE_HOST=http://localhost:3001
LANGFUSE_PORT=3001
LANGFUSE_DB_PASSWORD=replace-with-a-strong-password
LANGFUSE_AUTH_SECRET=replace-with-at-least-32-random-characters
LANGFUSE_SALT=replace-with-a-random-salt
LANGFUSE_TELEMETRY=false

# Optional local LLM: docker compose --profile local-llm up -d
OLLAMA_PORT=11434
