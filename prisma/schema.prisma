// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
}

// --------------------------------------------------------
// Authentication (Ť™ćŤ®ľ)
// --------------------------------------------------------
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String
  role           String    @default("viewer") // admin, editor, viewer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@index([userId])
}

// --------------------------------------------------------
// Issue Management
// --------------------------------------------------------
model Issue {
  id          String   @id @default(cuid())
  humanId     String   @unique // Ť°®Á§ļÁĒ®ID (šĺč: ISS-001)
  title       String
  description String

  // Status Management (enumŚĆĖ)
  // values: 'new', 'triage', 'in-progress', 'proposed', 'merged', 'rejected', 'merged-duplicate'
  status String @default("new")

  // Kind: 'problem' (śĒĻŚĖĄ„Āó„Āü„ĀĄŤ™≤ť°Ć) | 'praise' (śĄüŤ¨Ě„ÉĽśąźŚäüšļčšĺč)
  kind String @default("problem")

  // Target Identification (YAML„Ā®„ĀģÁīźšĽė„ĀĎ)
  targetFlowId String? // ŚĮĺŤĪ°„Éē„ā°„ā§„ÉęŚźć (šĺč: order-process.yaml)
  targetNodeId String? // ŚĮĺŤĪ°„Éé„Éľ„ÉČID (šĺč: node_123)

  // Duplicate Handling logic (ťáćŤ§áÁĶĪŚźą„É≠„āł„ÉÉ„āĮ)
  canonicalId    String? // ÁĶĪŚźąŚÖą„ĀģŤ¶™Issue ID
  canonicalIssue Issue?  @relation("Duplicates", fields: [canonicalId], references: [id])
  duplicates     Issue[] @relation("Duplicates")

  // Git Operations
  branchName String? // šĹúś•≠ÁĒ®„ÉĖ„É©„É≥„ÉĀ (šĺč: cr/ISS-001-fix-typo)

  // Relationships
  proposals Proposal[]
  evidences Evidence[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // „āĹ„Éē„Éą„Éá„É™„Éľ„Éą

  // Indexes for better query performance
  @@index([status])
  @@index([targetFlowId])
  @@index([canonicalId])
  @@index([deletedAt])
  @@index([kind])
}

// --------------------------------------------------------
// Change Proposals (LLM or Manual)
// --------------------------------------------------------
model Proposal {
  id      String @id @default(cuid())
  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  intent      String // Ś§ČśõīśĄŹŚõ≥„ĀģŤ¶ĀÁīĄ
  jsonPatch   String // JSON PatchŚĹĘŚľŹ„ĀģŚ∑ģŚąÜ„Éá„Éľ„āŅ (JSONśĖáŚ≠óŚąó„Ā®„Āó„Ā¶šŅĚŚ≠ė)
  diffPreview String? // Ť°®Á§ļÁĒ®„ĀģDiffÔľą„ÉÜ„ā≠„āĻ„Éą„Āĺ„Āü„ĀĮHTMLÔľČ

  // baseHash for staleness detection (ťô≥ŤÖźŚĆĖś§úÁü•)
  baseHash     String? // śŹźś°ąÁĒüśąźśôāÁāĻ„ĀģŚĮĺŤĪ°YAML„Āģ„ÉŹ„ÉÉ„ā∑„É•
  targetFlowId String? // ŚĮĺŤĪ°„Éē„É≠„ÉľID

  isApplied Boolean   @default(false) // ťĀ©ÁĒ®śłą„ĀŅ„Éē„É©„āį
  appliedAt DateTime?

  createdAt DateTime @default(now())

  @@index([issueId])
  @@index([isApplied])
}

// --------------------------------------------------------
// Evidences
// --------------------------------------------------------
model Evidence {
  id      String @id @default(cuid())
  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  type String // 'screenshot', 'link', 'text_log'
  url  String // „Éē„ā°„ā§„Éę„ÉĎ„āĻ„Āĺ„Āü„ĀĮURL
  note String?

  createdAt DateTime @default(now())

  @@index([issueId])
}

// --------------------------------------------------------
// Audit Log (Áõ£śüĽ„É≠„āį)
// --------------------------------------------------------
model AuditLog {
  id String @id @default(cuid())

  actor  String @default("you") // MVP: ŚõļŚģö
  action String // ISSUE_CREATE, PROPOSAL_GENERATE, PATCH_APPLY, MERGE_CLOSE, DUPLICATE_MERGE, etc.

  entityType String // Issue, Proposal, Flow, WorkflowExecution
  entityId   String

  traceId String? // Trace IDÔľą„ÉĮ„Éľ„āĮ„Éē„É≠„ÉľŚģüŤ°Ć„ĀģE2E„Éą„É¨„Éľ„āĶ„Éď„É™„ÉÜ„ā£ÁĒ®ÔľČ

  payload String? // Ś∑ģŚąÜ„āĄÁźÜÁĒĪ„Ā™„Ā© (JSONśĖáŚ≠óŚąó„Ā®„Āó„Ā¶šŅĚŚ≠ė)

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([traceId])
  @@index([createdAt])
}

// --------------------------------------------------------
// Workflow ExecutionÔľą„ÉĮ„Éľ„āĮ„Éē„É≠„ÉľŚģüŤ°ĆÔľČ
// --------------------------------------------------------
model WorkflowExecution {
  id            String   @id @default(cuid())
  flowId        String
  traceId       String   @unique
  status        String   @default("running") // running, paused-human-review, completed, failed, cancelled
  currentNodeId String
  stateData     Json     @default("{}")
  initiatorId   String

  taskExecutions   TaskExecution[]
  approvalRequests ApprovalRequest[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([flowId])
  @@index([status])
}

// --------------------------------------------------------
// Task ExecutionÔľą„āŅ„āĻ„āĮŚģüŤ°ĆŤ®ėťĆ≤ÔľČ
// --------------------------------------------------------
model TaskExecution {
  id            String            @id @default(cuid())
  workflowId    String
  workflow      WorkflowExecution @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeId        String
  taskId        String
  taskVersion   String
  gitCommitHash String

  status String @default("pending") // pending, running, success, failure
  input  Json
  output Json?

  llmModelUsed    String?
  llmTokensInput  Int?
  llmTokensOutput Int?
  durationMs      Int?

  traceId String

  error Json?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([workflowId])
  @@index([traceId])
  @@index([taskId])
}

// --------------------------------------------------------
// Approval RequestÔľąHuman-in-the-loopśČŅŤ™ćŤ¶ĀśĪāÔľČ
// --------------------------------------------------------
model ApprovalRequest {
  id         String            @id @default(cuid())
  workflowId String
  workflow   WorkflowExecution @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeId     String

  description String
  context     Json // śČŅŤ™ćŤÄÖ„ĀęśŹźÁ§ļ„Āô„āč„ā≥„É≥„ÉÜ„ā≠„āĻ„ÉąśÉÖŚ†Ī

  status    String    @default("pending") // pending, approved, rejected
  decision  String? // approved / rejected
  reason    String? // ISO 42001: śČŅŤ™ć/Śź¶Ť™ć„ĀģÁźÜÁĒĪ„ĀĮŚŅÖť†ąŤ®ėťĆ≤
  decidedBy String?
  decidedAt DateTime?

  createdAt DateTime @default(now())

  @@index([workflowId])
  @@index([status])
}

// --------------------------------------------------------
// Data ObjectÔľąGPTsiteki Section 10.5 „Éá„Éľ„āŅ„ā™„ÉĖ„āł„āß„āĮ„ÉąÔľČ
// --------------------------------------------------------
model DataObject {
  id       String @id @default(cuid())
  objectId String @unique // „Éď„āł„Éć„āĻID (e.g., "obj-2026-000123")

  parentId        String? // Ť¶™DataObject„ĀģobjectId
  objectType      String // document, fragment, semantic-object, evidence-link, transformation-event
  sensitivityLevel String @default("L1") // L0-L5
  sourceHash      String?
  owner           String?
  version         String?

  accessPolicyRef String? // access-policies.yaml „Āģ„ā≠„ÉľŚŹāÁÖß
  contentRef      String?
  exportPolicy    String  @default("unrestricted")

  semanticTags    Json? // String[] as JSON
  provenanceRef   String?
  validationRef   String?
  validationStatus String? // unverified, machine-verified, human-verified, official

  fragmentType       String?
  semanticObjectType String?
  abstractionMetadata    Json? // AbstractionMetadata as JSON
  outputArtifactMetadata Json? // OutputArtifactMetadata as JSON
  meta                   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  crossRefsAsSource      CrossReference[]      @relation("SourceObject")
  crossRefsAsTarget      CrossReference[]      @relation("TargetObject")
  evidenceLinksAsClaim   DataEvidenceLink[]    @relation("ClaimObject")
  evidenceLinksAsEvidence DataEvidenceLink[]    @relation("EvidenceObject")
  transformationInputs   TransformationInput[]
  transformationOutputs  TransformationOutput[]

  @@index([objectType])
  @@index([sensitivityLevel])
  @@index([parentId])
  @@index([owner])
  @@index([validationStatus])
}

// --------------------------------------------------------
// Cross ReferenceÔľąGPTsiteki Section 10.6 ś®™śĖ≠ŚŹāÁÖßÔľČ
// --------------------------------------------------------
model CrossReference {
  id             String @id @default(cuid())
  refId          String @unique // „Éď„āł„Éć„āĻID (e.g., "xref-001")
  sourceObjectId String
  targetObjectId String
  referenceType  String // cites, derived-from, related-to, supersedes, contradicts, abstracts
  description    String?

  sourceObject DataObject @relation("SourceObject", fields: [sourceObjectId], references: [objectId])
  targetObject DataObject @relation("TargetObject", fields: [targetObjectId], references: [objectId])

  createdAt DateTime @default(now())

  @@index([sourceObjectId])
  @@index([targetObjectId])
  @@index([referenceType])
}

// --------------------------------------------------------
// Data Evidence LinkÔľąGPTsiteki Section 10.2 ś†Ļśč†„É™„É≥„āĮÔľČ
// --------------------------------------------------------
model DataEvidenceLink {
  id               String @id @default(cuid())
  linkId           String @unique // „Éď„āł„Éć„āĻID (e.g., "el-001")
  claimObjectId    String
  evidenceObjectId String
  relationshipType String // supports, contradicts, supplements, derives-from, references
  confidence       Float?
  description      String?

  claimObject    DataObject @relation("ClaimObject", fields: [claimObjectId], references: [objectId])
  evidenceObject DataObject @relation("EvidenceObject", fields: [evidenceObjectId], references: [objectId])

  createdAt DateTime @default(now())

  @@index([claimObjectId])
  @@index([evidenceObjectId])
  @@index([relationshipType])
}

// --------------------------------------------------------
// Transformation EventÔľąGPTsiteki Section 10.2 Ś§ČśŹõ„ā§„Éô„É≥„ÉąÔľČ
// --------------------------------------------------------
model TransformationEvent {
  id         String   @id @default(cuid())
  eventId    String   @unique // „Éď„āł„Éć„āĻID (e.g., "te-001")
  type       String // ocr, extraction, conversion, summarization, verification, approval, abstraction
  executedBy String
  executedAt DateTime
  parameters Json?
  confidence Float?
  metadata   Json?

  inputs  TransformationInput[]
  outputs TransformationOutput[]

  createdAt DateTime @default(now())

  @@index([type])
  @@index([executedAt])
}

// --------------------------------------------------------
// Transformation M:N Junction Tables
// --------------------------------------------------------
model TransformationInput {
  id                    String              @id @default(cuid())
  transformationEventId String
  dataObjectId          String
  event                 TransformationEvent @relation(fields: [transformationEventId], references: [id], onDelete: Cascade)
  dataObject            DataObject          @relation(fields: [dataObjectId], references: [objectId])

  @@unique([transformationEventId, dataObjectId])
}

model TransformationOutput {
  id                    String              @id @default(cuid())
  transformationEventId String
  dataObjectId          String
  event                 TransformationEvent @relation(fields: [transformationEventId], references: [id], onDelete: Cascade)
  dataObject            DataObject          @relation(fields: [dataObjectId], references: [objectId])

  @@unique([transformationEventId, dataObjectId])
}
