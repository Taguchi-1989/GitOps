// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../node_modules/.prisma/client"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------
// Authentication (認証)
// --------------------------------------------------------
model User {
  id             String    @id @default(cuid())
  email          String    @unique
  name           String?
  hashedPassword String
  role           String    @default("viewer") // admin, editor, viewer

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions Session[]
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  expires      DateTime

  @@index([userId])
}

// --------------------------------------------------------
// Issue Management
// --------------------------------------------------------
model Issue {
  id          String   @id @default(cuid())
  humanId     String   @unique // 表示用ID (例: ISS-001)
  title       String
  description String

  // Status Management (enum化)
  // values: 'new', 'triage', 'in-progress', 'proposed', 'merged', 'rejected', 'merged-duplicate'
  status String @default("new")

  // Target Identification (YAMLとの紐付け)
  targetFlowId String? // 対象ファイル名 (例: order-process.yaml)
  targetNodeId String? // 対象ノードID (例: node_123)

  // Duplicate Handling logic (重複統合ロジック)
  canonicalId    String? // 統合先の親Issue ID
  canonicalIssue Issue?  @relation("Duplicates", fields: [canonicalId], references: [id])
  duplicates     Issue[] @relation("Duplicates")

  // Git Operations
  branchName String? // 作業用ブランチ (例: cr/ISS-001-fix-typo)

  // Relationships
  proposals Proposal[]
  evidences Evidence[]

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // ソフトデリート

  // Indexes for better query performance
  @@index([status])
  @@index([targetFlowId])
  @@index([canonicalId])
  @@index([deletedAt])
}

// --------------------------------------------------------
// Change Proposals (LLM or Manual)
// --------------------------------------------------------
model Proposal {
  id      String @id @default(cuid())
  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  intent      String // 変更意図の要約
  jsonPatch   String // JSON Patch形式の差分データ (JSON文字列として保存)
  diffPreview String? // 表示用のDiff（テキストまたはHTML）

  // baseHash for staleness detection (陳腐化検知)
  baseHash     String? // 提案生成時点の対象YAMLのハッシュ
  targetFlowId String? // 対象フローID

  isApplied Boolean   @default(false) // 適用済みフラグ
  appliedAt DateTime?

  createdAt DateTime @default(now())

  @@index([issueId])
  @@index([isApplied])
}

// --------------------------------------------------------
// Evidences
// --------------------------------------------------------
model Evidence {
  id      String @id @default(cuid())
  issueId String
  issue   Issue  @relation(fields: [issueId], references: [id], onDelete: Cascade)

  type String // 'screenshot', 'link', 'text_log'
  url  String // ファイルパスまたはURL
  note String?

  createdAt DateTime @default(now())

  @@index([issueId])
}

// --------------------------------------------------------
// Audit Log (監査ログ)
// --------------------------------------------------------
model AuditLog {
  id String @id @default(cuid())

  actor  String @default("you") // MVP: 固定
  action String // ISSUE_CREATE, PROPOSAL_GENERATE, PATCH_APPLY, MERGE_CLOSE, DUPLICATE_MERGE, etc.

  entityType String // Issue, Proposal, Flow, WorkflowExecution
  entityId   String

  traceId String? // Trace ID（ワークフロー実行のE2Eトレーサビリティ用）

  payload String? // 差分や理由など (JSON文字列として保存)

  createdAt DateTime @default(now())

  @@index([entityType, entityId])
  @@index([action])
  @@index([traceId])
  @@index([createdAt])
}

// --------------------------------------------------------
// Workflow Execution（ワークフロー実行）
// --------------------------------------------------------
model WorkflowExecution {
  id            String   @id @default(cuid())
  flowId        String
  traceId       String   @unique
  status        String   @default("running") // running, paused-human-review, completed, failed, cancelled
  currentNodeId String
  stateData     Json     @default("{}")
  initiatorId   String

  taskExecutions   TaskExecution[]
  approvalRequests ApprovalRequest[]

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([flowId])
  @@index([status])
}

// --------------------------------------------------------
// Task Execution（タスク実行記録）
// --------------------------------------------------------
model TaskExecution {
  id            String            @id @default(cuid())
  workflowId    String
  workflow      WorkflowExecution @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeId        String
  taskId        String
  taskVersion   String
  gitCommitHash String

  status String @default("pending") // pending, running, success, failure
  input  Json
  output Json?

  llmModelUsed    String?
  llmTokensInput  Int?
  llmTokensOutput Int?
  durationMs      Int?

  traceId String

  error Json?

  createdAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([workflowId])
  @@index([traceId])
  @@index([taskId])
}

// --------------------------------------------------------
// Approval Request（Human-in-the-loop承認要求）
// --------------------------------------------------------
model ApprovalRequest {
  id         String            @id @default(cuid())
  workflowId String
  workflow   WorkflowExecution @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  nodeId     String

  description String
  context     Json // 承認者に提示するコンテキスト情報

  status    String    @default("pending") // pending, approved, rejected
  decision  String? // approved / rejected
  reason    String? // ISO 42001: 承認/否認の理由は必須記録
  decidedBy String?
  decidedAt DateTime?

  createdAt DateTime @default(now())

  @@index([workflowId])
  @@index([status])
}

// --------------------------------------------------------
// Data Object（GPTsiteki Section 10.5 データオブジェクト）
// --------------------------------------------------------
model DataObject {
  id       String @id @default(cuid())
  objectId String @unique // ビジネスID (e.g., "obj-2026-000123")

  parentId        String? // 親DataObjectのobjectId
  objectType      String // document, fragment, semantic-object, evidence-link, transformation-event
  sensitivityLevel String @default("L1") // L0-L5
  sourceHash      String?
  owner           String?
  version         String?

  accessPolicyRef String? // access-policies.yaml のキー参照
  contentRef      String?
  exportPolicy    String  @default("unrestricted")

  semanticTags    Json? // String[] as JSON
  provenanceRef   String?
  validationRef   String?
  validationStatus String? // unverified, machine-verified, human-verified, official

  fragmentType       String?
  semanticObjectType String?
  abstractionMetadata    Json? // AbstractionMetadata as JSON
  outputArtifactMetadata Json? // OutputArtifactMetadata as JSON
  meta                   Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations
  crossRefsAsSource      CrossReference[]      @relation("SourceObject")
  crossRefsAsTarget      CrossReference[]      @relation("TargetObject")
  evidenceLinksAsClaim   DataEvidenceLink[]    @relation("ClaimObject")
  evidenceLinksAsEvidence DataEvidenceLink[]    @relation("EvidenceObject")
  transformationInputs   TransformationInput[]
  transformationOutputs  TransformationOutput[]

  @@index([objectType])
  @@index([sensitivityLevel])
  @@index([parentId])
  @@index([owner])
  @@index([validationStatus])
}

// --------------------------------------------------------
// Cross Reference（GPTsiteki Section 10.6 横断参照）
// --------------------------------------------------------
model CrossReference {
  id             String @id @default(cuid())
  refId          String @unique // ビジネスID (e.g., "xref-001")
  sourceObjectId String
  targetObjectId String
  referenceType  String // cites, derived-from, related-to, supersedes, contradicts, abstracts
  description    String?

  sourceObject DataObject @relation("SourceObject", fields: [sourceObjectId], references: [objectId])
  targetObject DataObject @relation("TargetObject", fields: [targetObjectId], references: [objectId])

  createdAt DateTime @default(now())

  @@index([sourceObjectId])
  @@index([targetObjectId])
  @@index([referenceType])
}

// --------------------------------------------------------
// Data Evidence Link（GPTsiteki Section 10.2 根拠リンク）
// --------------------------------------------------------
model DataEvidenceLink {
  id               String @id @default(cuid())
  linkId           String @unique // ビジネスID (e.g., "el-001")
  claimObjectId    String
  evidenceObjectId String
  relationshipType String // supports, contradicts, supplements, derives-from, references
  confidence       Float?
  description      String?

  claimObject    DataObject @relation("ClaimObject", fields: [claimObjectId], references: [objectId])
  evidenceObject DataObject @relation("EvidenceObject", fields: [evidenceObjectId], references: [objectId])

  createdAt DateTime @default(now())

  @@index([claimObjectId])
  @@index([evidenceObjectId])
  @@index([relationshipType])
}

// --------------------------------------------------------
// Transformation Event（GPTsiteki Section 10.2 変換イベント）
// --------------------------------------------------------
model TransformationEvent {
  id         String   @id @default(cuid())
  eventId    String   @unique // ビジネスID (e.g., "te-001")
  type       String // ocr, extraction, conversion, summarization, verification, approval, abstraction
  executedBy String
  executedAt DateTime
  parameters Json?
  confidence Float?
  metadata   Json?

  inputs  TransformationInput[]
  outputs TransformationOutput[]

  createdAt DateTime @default(now())

  @@index([type])
  @@index([executedAt])
}

// --------------------------------------------------------
// Transformation M:N Junction Tables
// --------------------------------------------------------
model TransformationInput {
  id                    String              @id @default(cuid())
  transformationEventId String
  dataObjectId          String
  event                 TransformationEvent @relation(fields: [transformationEventId], references: [id], onDelete: Cascade)
  dataObject            DataObject          @relation(fields: [dataObjectId], references: [objectId])

  @@unique([transformationEventId, dataObjectId])
}

model TransformationOutput {
  id                    String              @id @default(cuid())
  transformationEventId String
  dataObjectId          String
  event                 TransformationEvent @relation(fields: [transformationEventId], references: [id], onDelete: Cascade)
  dataObject            DataObject          @relation(fields: [dataObjectId], references: [objectId])

  @@unique([transformationEventId, dataObjectId])
}
